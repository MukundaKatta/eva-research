# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key for the summarizer (claude-sonnet-4-6)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional — enables richer data per source ─────────────────────────────────

# X/Twitter v2 Bearer token.
# Without this the adapter uses public Nitter-style RSS mirrors (may be flaky).
X_BEARER_TOKEN=

# YouTube Data API v3 key.
# Without this the adapter falls back to scraping the trending page (best-effort).
YOUTUBE_API_KEY=

# ── Tuning ────────────────────────────────────────────────────────────────────
# How many days back to ingest (default: 7)
LOOKBACK_DAYS=7

# Comma-separated subreddits to monitor (overrides feeds.yaml defaults)
# REDDIT_SUBREDDITS=Entrepreneur,startups,SideProject,indiehackers,marketing

# Path to custom RSS feeds YAML (default: feeds.yaml in project root)
# RSS_FEEDS_FILE=feeds.yaml
